{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "marketplace": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "owner": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "email": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": {}
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "owner"
      ],
      "additionalProperties": false
    },
    "categories": {
      "type": "object",
      "properties": {
        "allowed": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        }
      },
      "required": [
        "allowed"
      ],
      "additionalProperties": false
    },
    "plugin": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "version-source": {
            "default": "changesets",
            "type": "string",
            "enum": [
              "changesets",
              "manual"
            ]
          },
          "version": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "skills": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "agents": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hooks": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mcp": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "commands": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "version-source",
          "skills",
          "agents",
          "hooks",
          "mcp",
          "commands"
        ],
        "additionalProperties": false
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "max-skill-body-tokens": {
          "default": 5000,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "max-listing-chars": {
          "default": 1536,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "min-trigger-hit-rate": {
          "default": 0.85,
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "security-tier": {
          "default": "strict",
          "type": "string",
          "enum": [
            "strict",
            "standard"
          ]
        },
        "network-allowlist": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "composition-allowlist": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "max-skill-body-tokens",
        "max-listing-chars",
        "min-trigger-hit-rate",
        "security-tier",
        "network-allowlist",
        "composition-allowlist"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "marketplace",
    "categories",
    "plugin",
    "policy"
  ],
  "additionalProperties": false
}
