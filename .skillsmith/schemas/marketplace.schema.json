{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "owner": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": {}
    },
    "description": {
      "type": "string"
    },
    "plugins": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "source": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "const": "github"
                  },
                  "repo": {
                    "type": "string",
                    "pattern": "^[\\w.-]+\\/[\\w.-]+$"
                  },
                  "ref": {
                    "type": "string"
                  },
                  "sha": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{7,40}$"
                  }
                },
                "required": [
                  "source",
                  "repo"
                ],
                "additionalProperties": {}
              },
              {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "const": "url"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "sha": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{7,40}$"
                  }
                },
                "required": [
                  "source",
                  "url"
                ],
                "additionalProperties": {}
              },
              {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "const": "npm"
                  },
                  "package": {
                    "type": "string",
                    "minLength": 1
                  },
                  "version": {
                    "type": "string"
                  }
                },
                "required": [
                  "source",
                  "package"
                ],
                "additionalProperties": {}
              }
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "source"
        ],
        "additionalProperties": {}
      }
    }
  },
  "required": [
    "name",
    "owner",
    "plugins"
  ],
  "additionalProperties": {}
}
