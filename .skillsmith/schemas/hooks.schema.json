{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "propertyNames": {
    "type": "string"
  },
  "additionalProperties": {
    "type": "array",
    "items": {
      "type": "object",
      "properties": {
        "matcher": {
          "type": "string"
        },
        "if": {
          "type": "string"
        },
        "hooks": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "command",
                  "http",
                  "mcp_tool",
                  "prompt",
                  "agent"
                ]
              },
              "command": {
                "type": "string"
              },
              "prompt": {
                "type": "string"
              },
              "comment": {
                "type": "string"
              },
              "timeout": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "type"
            ],
            "additionalProperties": {}
          }
        }
      },
      "required": [
        "hooks"
      ],
      "additionalProperties": {}
    }
  }
}
